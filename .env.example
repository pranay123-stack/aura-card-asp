# Copy to .env and fill in. .env is gitignored — never commit real values.

# ---- Reading provider (the LLM that writes the reading + palette + visual DNA) ----
# Pick ONE. Defaults to OpenAI when OPENAI_API_KEY is set, else Anthropic.
# Override explicitly with READING_PROVIDER=openai | anthropic.

# Option A — OpenAI (set this and the reading uses OpenAI automatically):
# OPENAI_API_KEY=sk-...
# OPENAI_READING_MODEL=gpt-4o        # any model that supports structured outputs + vision

# Option B — Anthropic / Claude:
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-opus-4-8

# ---- Artwork (optional) ----
# Set OPENAI_API_KEY to draw the illustration with gpt-image-1 (~$0.02-0.04/call,
# +10-20s). Leave it unset and the procedural engine draws it instead: free, ~50ms,
# deterministic. Either way you get a complete card — an OpenAI failure (timeout,
# rate limit, outage, refusal) falls back to procedural rather than failing the call.
# OPENAI_API_KEY=sk-...
# IMAGE_PROVIDER=openai          # or 'procedural' to force it off while the key is set
# IMAGE_TIMEOUT_MS=25000         # image deadline before falling back
# GENERATION_TIMEOUT_MS=60000    # whole-pipeline deadline (defaults to 60s with OpenAI, 30s without)

# ---- OKX x402 payments (required in production) ----
# From the OnchainOS Developer Portal: https://web3.okx.com/onchainos/dev-portal
OKX_API_KEY=
OKX_SECRET_KEY=
OKX_PASSPHRASE=

# Your wallet on X Layer. This is where the USDT lands.
PAY_TO=0x...

# Price per call. PRICE is what the SDK charges; FEE_USDT is the bare number the
# ASP registry wants. Keep them consistent — a mismatch is a listing rejection.
PRICE=$0.50
FEE_USDT=0.5

# ---- Deployment ----
PORT=8080
PUBLIC_URL=https://your-service.onrender.com

# ---- Local dev only ----
# Skips the payment layer entirely so you can iterate without OKX keys or spending
# USDT. NEVER set this on the deployed ASP: the service would answer for free.
# PAYMENTS_DISABLED=true
