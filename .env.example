# Copy to .env and fill in. .env is gitignored — never commit real values.

# ---- Anthropic (required) ----
# The reading, palette, and visual DNA all come from one Claude call.
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-opus-4-8

# ---- OKX x402 payments (required in production) ----
# From the OnchainOS Developer Portal: https://web3.okx.com/onchainos/dev-portal
OKX_API_KEY=
OKX_SECRET_KEY=
OKX_PASSPHRASE=

# Your wallet on X Layer. This is where the USDT lands.
PAY_TO=0x...

# Price per call. PRICE is what the SDK charges; FEE_USDT is the bare number the
# ASP registry wants. Keep them consistent — a mismatch is a listing rejection.
PRICE=$0.50
FEE_USDT=0.5

# ---- Deployment ----
PORT=8080
PUBLIC_URL=https://your-service.onrender.com

# ---- Local dev only ----
# Skips the payment layer entirely so you can iterate without OKX keys or spending
# USDT. NEVER set this on the deployed ASP: the service would answer for free.
# PAYMENTS_DISABLED=true
